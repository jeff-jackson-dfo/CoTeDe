    "        \"global_range\": {\"minval\": -2, \"maxval\": 40},\n",
    "        \"gradient\": {\"threshold\": 10.0},\n",
    "        \"spike\": {\"threshold\": 2.0},\n",
    "        \"tukey53H\": {\"threshold\": 1.5},\n",
    "    },\n",
    "    \"PSAL\": {\n",
    "        \"global_range\": {\"minval\": 0, \"maxval\": 41},\n",
    "        \"gradient\": {\"threshold\": 5.0},\n",
